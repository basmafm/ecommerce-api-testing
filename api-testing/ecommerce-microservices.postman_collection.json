                  "\r",
                  "let json = pm.response.json();\r",
                  "\r",
                  "pm.environment.set(\"cart_id\", json.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
